---
interface Props { navDark?: boolean; }
const { navDark = false } = Astro.props;
---

{navDark ? (
  <div class="fixed bottom-0 left-0 right-0 z-50 dark">
    <footer class="backdrop-blur-md border-t border-white/10 py-8 text-center text-sm text-gray-300">
      Gabriel Forn-Cuní · {new Date().getFullYear()}
    </footer>
  </div>
) : (
  <footer class="border-t border-gray-300 dark:border-white/10 py-8 text-center text-sm text-gray-400 dark:text-gray-500">
    Gabriel Forn-Cuní · {new Date().getFullYear()}
  </footer>
)}
